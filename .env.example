# Telegram bot credentials
# Create a bot with BotFather and paste its token into your local .env file.
TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token

# Optional: used when generating Telegram deep links.
BOT_USERNAME=PodarkiNeOtdarkiBot

# PostgreSQL connection string for local development or deployment.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wishes_simple_bot_development

# Required only when running with Rails encrypted credentials in production.
RAILS_MASTER_KEY=replace-with-your-rails-master-key

# Optional Rails/Puma runtime settings.
WEB_CONCURRENCY=2
SOLID_QUEUE_IN_PUMA=true
